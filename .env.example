# Database
DATABASE_URL="postgresql://onboarding:CHANGE_ME@db:5432/onboarding"

# PostgreSQL (used by the db service)
POSTGRES_USER=onboarding
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=onboarding

# Auth.js — generate with: openssl rand -base64 32
AUTH_SECRET=CHANGE_ME_USE_OPENSSL_RAND_BASE64_32

# App URL (must match deployment URL for CSRF protection)
NEXTAUTH_URL=http://localhost:3000

# Upload directory (mapped to Docker volume)
UPLOAD_DIR=/app/uploads

# Node environment
NODE_ENV=production

# Redis (used for distributed rate limiting in multi-instance deployments)
REDIS_URL=redis://redis:6379

# Optional: set initial admin password for first container boot.
# If unset, a random password is printed to stdout on first start.
# Generate with: openssl rand -base64 16
# ADMIN_BOOTSTRAP_PASSWORD=

# Set to any non-empty value when the app is behind a trusted reverse proxy
# (Nginx, Caddy, Traefik, etc.) that strips or overrides X-Forwarded-For.
# The proxy MUST be configured to not forward client-supplied X-Forwarded-For
# headers, otherwise clients can spoof their IP and bypass rate limits.
# Leave unset for direct access (local development without a proxy).
# TRUST_PROXY=true
