# Database
DATABASE_URL="postgresql://onboarding:CHANGE_ME@db:5432/onboarding"

# PostgreSQL (used by the db service)
POSTGRES_USER=onboarding
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=onboarding

# Auth.js — generate with: openssl rand -base64 32
AUTH_SECRET=CHANGE_ME_USE_OPENSSL_RAND_BASE64_32

# App URL (must match deployment URL for CSRF protection)
NEXTAUTH_URL=http://localhost:3000

# Upload directory (mapped to Docker volume)
UPLOAD_DIR=/app/uploads

# Node environment
NODE_ENV=production

# Redis authentication password — required; used by both the Redis service and the app.
# Generate with: openssl rand -base64 32
REDIS_PASSWORD=CHANGE_ME

# Redis connection URL — constructed from REDIS_PASSWORD above; do not set manually.
# Docker Compose substitutes REDIS_PASSWORD into this value at runtime.
# REDIS_URL is set automatically in docker-compose.yml; this line is for reference only.
# REDIS_URL=redis://:CHANGE_ME@redis:6379

# Required on first container boot to create the initial admin user.
# The seed script will exit with an error if this is not set.
# Generate with: openssl rand -base64 16
ADMIN_BOOTSTRAP_PASSWORD=CHANGE_ME

# Required if email is configured (SMTP or Entra ID). Must be a 64-character
# hex string (32 bytes). Generate with:
# node -e "process.stdout.write(require('crypto').randomBytes(32).toString('hex'))"
EMAIL_ENCRYPTION_KEY=CHANGE_ME_64_HEX_CHARS

# Required for POST /api/cron/overdue-tasks and POST /api/cron/log-cleanup.
# Generate with: openssl rand -base64 32
# If unset, the cron endpoint returns 503 and overdue notifications are disabled.
CRON_SECRET=CHANGE_ME

# Retention period for AppLog rows (days). Rows older than this are deleted by
# POST /api/cron/log-cleanup. Defaults to 90 days if unset.
# LOG_RETENTION_DAYS=90

# Set to any non-empty value when the app is behind a trusted reverse proxy
# (Nginx, Caddy, Traefik, etc.) that strips or overrides X-Forwarded-For.
# The proxy MUST be configured to not forward client-supplied X-Forwarded-For
# headers, otherwise clients can spoof their IP and bypass rate limits.
# WARNING: when unset, all login attempts share one rate-limit bucket keyed by
# username — any 10 failed attempts against the same username trigger a 15-minute
# lockout for that username. Set TRUST_PROXY=true once a reverse proxy is in place.
# TRUST_PROXY=true
