# Database
DATABASE_URL="postgresql://onboarding:CHANGE_ME@db:5432/onboarding"

# PostgreSQL (used by the db service)
POSTGRES_USER=onboarding
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=onboarding

# Auth.js — generate with: openssl rand -base64 32
AUTH_SECRET=CHANGE_ME_USE_OPENSSL_RAND_BASE64_32

# App URL (must match deployment URL for CSRF protection)
NEXTAUTH_URL=http://localhost:3000

# Upload directory (mapped to Docker volume)
UPLOAD_DIR=/app/uploads

# Node environment
NODE_ENV=production
