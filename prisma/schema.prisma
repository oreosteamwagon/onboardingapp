generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  PAYROLL
  HR
  SUPERVISOR
  ADMIN
}

enum TaskType {
  STANDARD
  UPLOAD
  LEARNING
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

model User {
  id                   String         @id @default(cuid())
  username             String         @unique
  email                String         @unique
  passwordHash         String
  role                 Role           @default(USER)
  active               Boolean        @default(true)
  createdAt            DateTime       @default(now())
  firstName            String?
  lastName             String?
  preferredFirstName   String?
  preferredLastName    String?
  department           String?
  positionCode         String?
  userTasks              UserTask[]
  approvedUserTasks      UserTask[]       @relation("TaskApprover")
  documents              Document[]
  userWorkflows          UserWorkflow[]   @relation("WorkflowUser")
  supervisedWorkflows    UserWorkflow[]   @relation("WorkflowSupervisor")
  assignedWorkflowsBy    UserWorkflow[]   @relation("WorkflowAssigner")
  uploadedAttachments    TaskAttachment[] @relation("AttachmentUploader")
  authoredCourses        Course[]         @relation("CourseAuthor")
  courseAttempts         CourseAttempt[]  @relation("UserAttempts")

  @@index([username])
  @@index([email])
}

model BrandingSetting {
  id           String   @id @default(cuid())
  orgName      String   @default("My Organization")
  logoPath     String?
  primaryColor String   @default("#2563eb")
  accentColor  String   @default("#7c3aed")
  updatedAt    DateTime @updatedAt
}

model DocumentCategory {
  id        String   @id @default(cuid())
  slug      String   @unique
  name      String
  isBuiltIn Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([slug])
  @@index([name])
}

model OnboardingTask {
  id                 String          @id @default(cuid())
  title              String
  description        String?
  taskType           TaskType        @default(STANDARD)
  order              Int             @default(0)
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  resourceDocumentId String?
  courseId           String?
  resourceDocument   Document?       @relation("TaskResource", fields: [resourceDocumentId], references: [id])
  course             Course?         @relation("TaskCourse", fields: [courseId], references: [id])
  userTasks          UserTask[]
  workflowTasks      WorkflowTask[]
  courseAttempts     CourseAttempt[]

  @@index([courseId])
}

model UserTask {
  id             String           @id @default(cuid())
  userId         String
  taskId         String
  completed      Boolean          @default(false)
  completedAt    DateTime?
  documentId     String?          @unique
  approvalStatus ApprovalStatus   @default(PENDING)
  approvedAt     DateTime?
  approvedById   String?
  user           User             @relation(fields: [userId], references: [id])
  task           OnboardingTask   @relation(fields: [taskId], references: [id])
  document       Document?        @relation(fields: [documentId], references: [id])
  approvedBy     User?            @relation("TaskApprover", fields: [approvedById], references: [id])
  attachments    TaskAttachment[]

  @@unique([userId, taskId])
  @@index([userId])
  @@index([taskId])
  @@index([approvedById])
}

model Document {
  id          String           @id @default(cuid())
  uploadedBy  String
  filename    String
  storagePath String?          @unique
  url         String?
  category    String           @default("general")
  uploadedAt  DateTime         @default(now())
  isResource  Boolean          @default(false)
  uploader    User             @relation(fields: [uploadedBy], references: [id])
  // userTask is null for general documents; set when document proves an UPLOAD task completion
  userTask    UserTask?
  linkedTasks OnboardingTask[] @relation("TaskResource")

  @@index([uploadedBy])
}

model Workflow {
  id            String         @id @default(cuid())
  name          String         @unique
  description   String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  tasks         WorkflowTask[]
  userWorkflows UserWorkflow[]
}

// Junction table: which tasks belong to which workflow, with per-workflow ordering
model WorkflowTask {
  id         String         @id @default(cuid())
  workflowId String
  taskId     String
  order      Int            @default(0)
  workflow   Workflow       @relation(fields: [workflowId], references: [id])
  task       OnboardingTask @relation(fields: [taskId], references: [id])

  @@unique([workflowId, taskId])
  @@index([workflowId])
  @@index([taskId])
}

// Files attached by HR+ staff to a specific user task assignment (given to the user)
model TaskAttachment {
  id           String   @id @default(cuid())
  userTaskId   String
  uploadedById String
  filename     String
  storagePath  String   @unique
  uploadedAt   DateTime @default(now())

  userTask     UserTask @relation(fields: [userTaskId], references: [id])
  uploadedBy   User     @relation("AttachmentUploader", fields: [uploadedById], references: [id])

  @@index([userTaskId])
  @@index([uploadedById])
}

// A user assigned to a workflow, with an optional supervisor as approver
model UserWorkflow {
  id           String   @id @default(cuid())
  userId       String
  workflowId   String
  supervisorId String?
  assignedAt   DateTime @default(now())
  assignedById String
  user         User     @relation("WorkflowUser", fields: [userId], references: [id])
  workflow     Workflow @relation(fields: [workflowId], references: [id])
  supervisor   User?    @relation("WorkflowSupervisor", fields: [supervisorId], references: [id])
  assignedBy   User     @relation("WorkflowAssigner", fields: [assignedById], references: [id])

  @@unique([userId, workflowId])
  @@index([userId])
  @@index([workflowId])
  @@index([supervisorId])
}

model Course {
  id           String           @id @default(cuid())
  title        String
  description  String?
  contentHtml  String
  passingScore Int
  createdById  String
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  createdBy    User             @relation("CourseAuthor", fields: [createdById], references: [id])
  questions    CourseQuestion[]
  attempts     CourseAttempt[]
  linkedTasks  OnboardingTask[] @relation("TaskCourse")

  @@index([createdById])
}

model CourseQuestion {
  id       String         @id @default(cuid())
  courseId String
  text     String
  order    Int            @default(0)
  course   Course         @relation(fields: [courseId], references: [id], onDelete: Cascade)
  answers  CourseAnswer[]

  @@index([courseId])
}

model CourseAnswer {
  id         String         @id @default(cuid())
  questionId String
  text       String
  isCorrect  Boolean        @default(false)
  order      Int            @default(0)
  question   CourseQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([questionId])
}

model CourseAttempt {
  id            String         @id @default(cuid())
  userId        String
  courseId      String
  taskId        String
  score         Int
  passed        Boolean
  attemptNumber Int
  completedAt   DateTime       @default(now())
  user          User           @relation("UserAttempts", fields: [userId], references: [id])
  course        Course         @relation(fields: [courseId], references: [id])
  task          OnboardingTask @relation(fields: [taskId], references: [id])

  @@index([userId])
  @@index([courseId])
  @@index([taskId])
  @@index([userId, courseId])
}
